		summarizeBy: sum
		sourceColumn: assists_per_90

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition fct_player_performance = m
		mode: import
		source =
				let
				    Source = GoogleBigQuery.Database([UseStorageApi=false]),
				    #"data-analiz-490513" = Source{[Name="data-analiz-490513"]}[Data],
				    football_mart_Schema = #"data-analiz-490513"{[Name="football_mart",Kind="Schema"]}[Data],
				    fct_player_performance_Table = football_mart_Schema{[Name="fct_player_performance",Kind="Table"]}[Data]
				in
				    fct_player_performance_Table

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

