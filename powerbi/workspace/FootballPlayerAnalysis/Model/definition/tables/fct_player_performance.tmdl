	column avg_minutes_per_match
		dataType: double
		summarizeBy: sum
		sourceColumn: avg_minutes_per_match

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column goals_per_match
