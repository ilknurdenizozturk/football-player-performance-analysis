table dim_players

	measure 'Total Players' = DISTINCTCOUNT(dim_players[player_id])
		formatString: 0

	column player_id
		dataType: int64
		formatString: 0
		summarizeBy: none
		sourceColumn: player_id

		annotation SummarizationSetBy = Automatic

	column player_name
		dataType: string
		summarizeBy: none
		sourceColumn: player_name

		annotation SummarizationSetBy = Automatic

	column position
		dataType: string
		summarizeBy: none
		sourceColumn: position

		annotation SummarizationSetBy = Automatic

	column sub_position
		dataType: string
		summarizeBy: none
		sourceColumn: sub_position

		annotation SummarizationSetBy = Automatic

	column birth_date
		dataType: dateTime
		formatString: Long Date
		summarizeBy: none
		sourceColumn: birth_date

		variation Variation
			isDefault
			relationship: c7b2052c-d1d6-4efa-a8f3-749a4155939b
			defaultHierarchy: LocalDateTable_f7e5ed87-c2d7-4b84-9d17-659cbdb1695e.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column country_of_birth
		dataType: string
		summarizeBy: none
		sourceColumn: country_of_birth

		annotation SummarizationSetBy = Automatic

	column country_of_citizenship
		dataType: string
		summarizeBy: none
		sourceColumn: country_of_citizenship

		annotation SummarizationSetBy = Automatic

	column height_in_cm
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: height_in_cm

		annotation SummarizationSetBy = Automatic

	column preferred_foot
		dataType: string
		summarizeBy: none
		sourceColumn: preferred_foot

		annotation SummarizationSetBy = Automatic

	column agent_name
		dataType: string
		summarizeBy: none
		sourceColumn: agent_name

		annotation SummarizationSetBy = Automatic

	column current_club_id
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: current_club_id

		annotation SummarizationSetBy = Automatic

	column current_club_name
		dataType: string
		summarizeBy: none
		sourceColumn: current_club_name

		annotation SummarizationSetBy = Automatic

	column last_season
		dataType: int64
		formatString: 0
		summarizeBy: sum
		sourceColumn: last_season

		annotation SummarizationSetBy = Automatic

	column player_record_type
		dataType: string
		summarizeBy: none
		sourceColumn: player_record_type

		annotation SummarizationSetBy = Automatic

	column player_profile_completeness_pct
		dataType: double
		summarizeBy: sum
		sourceColumn: player_profile_completeness_pct

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column player_name_display
		dataType: string
		summarizeBy: none
		sourceColumn: player_name_display

		annotation SummarizationSetBy = Automatic

	column position_display
		dataType: string
		summarizeBy: none
		sourceColumn: position_display

		annotation SummarizationSetBy = Automatic

	column current_club_name_display
		dataType: string
		summarizeBy: none
		sourceColumn: current_club_name_display

		annotation SummarizationSetBy = Automatic

	column has_current_profile
		dataType: boolean
		formatString: """TRUE"";""TRUE"";""FALSE"""
		summarizeBy: none
		sourceColumn: has_current_profile

		annotation SummarizationSetBy = Automatic

	column player_profile_completeness_status
		dataType: string
		summarizeBy: none
		sourceColumn: player_profile_completeness_status

		annotation SummarizationSetBy = Automatic

	column 'Age Group' = SWITCH(TRUE(), DATEDIFF(dim_players[birth_date], TODAY(), YEAR) < 22, "18-21", DATEDIFF(dim_players[birth_date], TODAY(), YEAR) < 26, "22-25", DATEDIFF(dim_players[birth_date], TODAY(), YEAR) < 30, "26-29", DATEDIFF(dim_players[birth_date], TODAY(), YEAR) < 34, "30-33", "34+")
		dataType: string
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition dim_players = m
		mode: import
		source =
				let
				    Source = GoogleBigQuery.Database([UseStorageApi=false]),
				    #"data-analiz-490513" = Source{[Name="data-analiz-490513"]}[Data],
				    football_mart_Schema = #"data-analiz-490513"{[Name="football_mart",Kind="Schema"]}[Data],
				    dim_players_Table = football_mart_Schema{[Name="dim_players",Kind="Table"]}[Data]
				in
				    dim_players_Table

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

