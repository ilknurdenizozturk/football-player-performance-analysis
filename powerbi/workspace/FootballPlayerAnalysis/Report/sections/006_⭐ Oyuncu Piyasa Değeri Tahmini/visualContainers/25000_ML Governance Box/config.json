                "spaceAfter": 3
              },
              {
                "textRuns": [
                  {
                    "value": "• Forvetler en yüksek medyan tahmin değerine sahiptir; model bu pozisyon dinamiğini bilinçli kalibre eder.",
                    "textStyle": {
                      "fontWeight": "normal",
                      "fontSize": "8.5pt",
