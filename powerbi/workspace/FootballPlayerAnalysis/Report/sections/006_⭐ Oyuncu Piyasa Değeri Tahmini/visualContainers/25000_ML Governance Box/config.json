              {
                "textRuns": [
                  {
                    "value": "• Forvetler en yüksek piyasa değerini taşır; model bu eşitsizliği pozisyon bazında doğru yakalar.",
                    "textStyle": {
                      "fontWeight": "normal",
                      "fontSize": "8pt",
                      "color": "#E6F2E8"
